# ─── Secure MCP Gateway — Environment Variables ───────────────

# Fernet key for token-at-rest encryption (generate with: python3 migrate_security.py --generate-encryption-key)
ENCRYPTION_KEY=""

# Set to "true" to allow unauthenticated requests (development only — NEVER in production)
DEV_MODE="false"

# ─── OAuth2 Multi-Tenant (Google Workspace) ──────────────────
# Create a "Web application" OAuth 2.0 Client ID in Google Cloud Console
# Authorized redirect URI: https://<your-domain>/oauth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# HMAC-SHA256 secret for JWT signing (generate with: python3 migrate_security.py --generate-jwt-secret)
# If unset, a random secret is generated at startup (sessions lost on restart)
JWT_SECRET=""

# Public hostname of the gateway (your domain, reverse proxy URL, tunnel endpoint, etc.)
# Used for DNS rebinding protection and OAuth issuer URL
GATEWAY_DOMAIN="your-domain.example.com"
# Override if the public URL differs from https://GATEWAY_DOMAIN
# OAUTH_ISSUER="https://your-domain.example.com"

# Restrict Google OAuth2 login to this email domain (leave empty to allow any Google account)
ALLOWED_EMAIL_DOMAIN="your-company.com"

# ─── Admin Panel ─────────────────────────────────────────────
# Comma-separated list of emails authorized to access the admin panel
ADMIN_EMAILS=""
ADMIN_PORT=8001
ADMIN_HOST="127.0.0.1"

# ─── Infrastructure (PostgreSQL + Redis) ─────────────────────
# Must match docker-compose.yaml settings (local dev)
DATABASE_URL="postgresql+asyncpg://mcp:changeme@localhost:5433/mcp_gateway"
REDIS_URL="redis://localhost:6380/0"

# TLS for managed PostgreSQL (set to "true" when using a managed DB with SSL)
# DATABASE_SSL="true"
# Connection pool tuning (default: 10 connections + 5 overflow per task)
# DATABASE_POOL_SIZE=10
# DATABASE_POOL_OVERFLOW=5

# ─── Container ───────────────────────────────────────────────
# Set to "true" to disable audit.log file (read-only filesystem)
# DISABLE_AUDIT_FILE="true"
# Set to "true" to start admin panel alongside gateway in same container
# ENABLE_ADMIN="true"
